<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <property name="connection.driver_class">org.h2.Driver</property>

        <property name="connection.url">jdbc:h2:~/banco;DB_CLOSE_DELAY=-1</property>
        <property name="connection.username">pedro</property>
        <property name="connection.password">macaco</property>

        <property name="dialect">org.hibernate.dialect.H2Dialect</property>

        <property name="hbm2ddl.auto">update</property>

        <property name="show_sql">true</property>
        <property name="format_sql">true</property>

        <mapping class="Entitys.EnderecoEntity"/>
        <mapping class="Entitys.PedidoEntity"/>
        <mapping class="Entitys.PedidoProdutoEntity"/>
        <mapping class="Entitys.PessoaEntity"/>
        <mapping class="Entitys.ProdutoEntity"/>
    </session-factory>
</hibernate-configuration>